rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Articles ────────────────────────────────────────────────────────────
    match /articles/{articleId} {

      // Anyone (authenticated or not) can read published articles
      allow read: if resource.data.isPublished == true;

      // Authenticated journalists can read their own drafts
      allow read: if request.auth != null
                  && resource.data.authorId == request.auth.uid;

      // Only authenticated users can create articles
      // and the authorId must match the caller's UID
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && isValidArticle(request.resource.data);

      // Only the original author can update their own article
      allow update: if request.auth != null
                    && resource.data.authorId == request.auth.uid
                    && request.resource.data.authorId == request.auth.uid
                    && isValidArticle(request.resource.data);

      // Only the original author can delete their own article
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {

      // Anyone authenticated can read public user profiles
      allow read: if request.auth != null;

      // Users can only write their own document
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ─── Likes ───────────────────────────────────────────────────────────────
    match /articles/{articleId}/likes/{userId} {
      // Anyone can read likes (for count and state)
      allow read: if true;

      // Only the user themselves can like/unlike
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ─── Comments ─────────────────────────────────────────────────────────────
    match /articles/{articleId}/comments/{commentId} {
      // Anyone can read comments
      allow read: if true;

      // Only authenticated users can create comments
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;

      // Only the comment author can delete their own comment
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;
    }

    // ─── Follows ─────────────────────────────────────────────────────────────
    match /follows/{followId} {

      // Anyone can read follows (needed for public follower counts)
      allow read: if true;

      // A user can only create a follow where they are the follower
      allow create: if request.auth != null
                    && request.resource.data.followerId == request.auth.uid;

      // Only the follower can delete their own follow
      allow delete: if request.auth != null
                    && resource.data.followerId == request.auth.uid;
    }
  }
}

// ─── Validation Functions ──────────────────────────────────────────────────

// Validates that an article document has all required fields with correct types
function isValidArticle(data) {
  return data.keys().hasAll([
           'id', 'authorId', 'author', 'title',
           'description', 'content', 'thumbnailPath',
           'thumbnailURL', 'publishedAt', 'updatedAt', 'isPublished'
         ])
      && data.id is string        && data.id.size() > 0
      && data.authorId is string  && data.authorId.size() > 0
      && data.author is string    && data.author.size() > 0
      && data.title is string     && data.title.size() > 0
                                  && data.title.size() <= 200
      && data.description is string && data.description.size() <= 500
      && data.content is string   && data.content.size() > 0
      && data.thumbnailPath is string
      && data.thumbnailURL is string
      && data.publishedAt is timestamp
      && data.updatedAt is timestamp
      && data.isPublished is bool;
}
